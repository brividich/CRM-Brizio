DJANGO_SECRET_KEY=CHANGE_ME
APP_VERSION=0.6.40-dev
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Impostare a 0 se il server è raggiungibile solo via HTTP (rete interna senza TLS).
# In produzione con HTTPS impostare tutti e 3 a 1.
SECURE_SSL_REDIRECT=0
CSRF_COOKIE_SECURE=0
SESSION_COOKIE_SECURE=0

DB_ENGINE=sqlite
DB_HOST=sqlserver.example.local
DB_NAME=project_db
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
# Impostare a 1 solo in sviluppo con certificati self-signed. In produzione lasciare 0.
DB_TRUST_CERT=0

LEGACY_AUTH_ENABLED=1
NAVIGATION_REGISTRY_ENABLED=1
NAVIGATION_LEGACY_FALLBACK_ENABLED=0
ASSENZE_SYNC_ON_PAGE_LOAD=0
SESSION_IDLE_TIMEOUT_SECONDS=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=1
LEGACY_ACL_CACHE_TTL=120
LEGACY_NAV_CACHE_TTL=120

LDAP_ENABLED=0
LDAP_SERVER=ldap://ldap.example.local
LDAP_DOMAIN=EXAMPLE
LDAP_UPN_SUFFIX=@example.local
LDAP_TIMEOUT=5
LDAP_SERVICE_USER=svc_ldap@example.local
LDAP_SERVICE_PASSWORD=CHANGE_ME
LDAP_BASE_DN=DC=EXAMPLE,DC=LOCAL
LDAP_USER_FILTER=(&(objectCategory=person)(objectClass=user))
LDAP_GROUP_ALLOWLIST=EMPLOYEES,MANAGERS,ADMINS
LDAP_SYNC_PAGE_SIZE=500

GRAPH_TENANT_ID=<GRAPH_TENANT_ID>
GRAPH_CLIENT_ID=<GRAPH_CLIENT_ID>
GRAPH_CLIENT_SECRET=<GRAPH_CLIENT_SECRET>
GRAPH_SITE_ID=<GRAPH_SITE_ID>
GRAPH_LIST_ID_ASSENZE=<GRAPH_LIST_ID_ASSENZE>
GRAPH_LIST_ID_DIPENDENTI=<GRAPH_LIST_ID_DIPENDENTI>
GRAPH_LIST_ID_CAPOREPARTO=<GRAPH_LIST_ID_CAPOREPARTO>
GRAPH_LIST_ID_ANOMALIE_DB=<GRAPH_LIST_ID_ANOMALIE_DB>

ASSENZE_SP_PULL_INTERVAL_SECONDS=300
ASSENZE_CALENDAR_MAX_EVENTS=1500
ASSENZE_CALENDAR_COLORS_CACHE_TTL=300

# SQL query logging (utile in sviluppo, disabilitare in produzione)
SQL_LOG_ENABLED=0
SQL_LOG_LEVEL=DEBUG
SQL_LOG_FORCE_DEBUG_CURSOR=0
SQL_LOG_MAX_BYTES=10485760
SQL_LOG_BACKUP_COUNT=10

# SMTP (usato dal modulo Automazioni per azioni SEND_EMAIL)
EMAIL_HOST=smtp.example.local
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=CHANGE_ME
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=portale@example.local
